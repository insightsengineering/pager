# create a simple gt table
gt_tbl <- data.frame(
x = c("laksdjhgkjhsdkfjhgkjl hegou zhiujzetjswrajhsjefg", "hh"),
y = c(10, 100)
) |>
gt() |>
cols_width(
x ~ px(100),
y ~ px(100)
)
# save as docx using gt::gtsave
filename = tempfile(fileext = ".docx")
gt::gtsave(gt_tbl, filename = filename)
